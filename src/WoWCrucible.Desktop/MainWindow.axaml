<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:WoWCrucible.Desktop.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1440" d:DesignHeight="900"
        x:Class="WoWCrucible.Desktop.MainWindow"
        Title="WoW Crucible"
        WindowStartupLocation="CenterScreen">
    <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="1.1*,Auto,3*,Auto,1.5*">
        <Border x:Name="MainHeader" Grid.Row="0" Grid.ColumnSpan="5" BorderBrush="#2B3445" BorderThickness="0,0,0,1">
            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" Margin="14,4">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="9" Margin="0,2,10,4">
                    <TextBlock Text="WOW CRUCIBLE" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
                    <TextBlock x:Name="BuildIdentityText" Foreground="#7F8A9F" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
                <WrapPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <ToggleSwitch x:Name="DevbugModeToggle" OnContent="DEVBUG ON" OffContent="DEVBUG OFF" IsCheckedChanged="DevbugModeChanged" />
                    <Border Margin="8,0,0,0" Padding="9,5" CornerRadius="5" Background="#13251F" BorderBrush="#285845" BorderThickness="1">
                        <TextBlock Text="AVALONIA PREVIEW" Foreground="#79D7A8" FontSize="11" FontWeight="SemiBold" />
                    </Border>
                </WrapPanel>
                <ScrollViewer Grid.Row="1" Grid.ColumnSpan="2" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <WrapPanel Orientation="Horizontal">
                        <Button Margin="0,0,8,0" Classes="accent" Content="Open DBC" Click="OpenDbcClick" />
                        <Button Margin="0,0,8,0" Content="Open M2" Click="OpenM2Click" />
                        <Button Margin="0,0,8,0" Content="Save" Click="SaveClick" />
                        <Button Margin="0,0,8,0" Content="Save As" Click="SaveAsClick" />
                        <Button Margin="0,0,8,0" Content="Export rows" Click="OpenDbcExportClick" />
                        <Button Margin="0,0,8,0" Content="Import rows" Click="OpenDbcImportClick" />
                        <Button Margin="0,0,8,0" Content="Close" Click="CloseDocumentClick" />
                        <Button Margin="0,0,8,0" Content="Logs" Click="OpenLogsClick" />
                        <Button Margin="0,0,8,0" Content="CLI Guide" Click="OpenCliGuideClick" />
                        <Button Margin="0,0,8,0" Content="Commands · Ctrl+K" Click="OpenCommandPaletteClick" />
                        <TextBox x:Name="SearchBox" PlaceholderText="Search loaded table…" TextChanged="SearchChanged" />
                    </WrapPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border x:Name="NavigationPane" Grid.Row="1" Grid.Column="0" BorderBrush="#2B3445" BorderThickness="0,0,1,0" Background="#0E1219">
            <Grid RowDefinitions="Auto,*,Auto" Margin="12">
                <TextBlock Text="WORKSPACE" Foreground="#7F8A9F" FontSize="10" FontWeight="Bold" Margin="6,4,0,9" />
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="4">
                        <Button HorizontalContentAlignment="Left" Click="OpenEditorWorkspaceClick"><TextBlock Text="▦  DBC tables" TextWrapping="Wrap" /></Button>
                        <Button HorizontalContentAlignment="Left" Click="OpenLayeredDbcsClick"><TextBlock Text="◫  DBC layers &amp; promotion" TextWrapping="Wrap" /></Button>
                        <Button HorizontalContentAlignment="Left" Click="OpenDbdSchemasClick"><TextBlock Text="≣  DBD schemas &amp; audit" TextWrapping="Wrap" /></Button>
                        <Button HorizontalContentAlignment="Left" Click="OpenProjectWorkspaceClick"><TextBlock Text="◆  Projects &amp; shared IDs" TextWrapping="Wrap" /></Button>
                        <Button HorizontalContentAlignment="Left" Click="OpenItemWorkbenchClick"><TextBlock Text="◈  Items &amp; sets" TextWrapping="Wrap" /></Button>
                        <Button HorizontalContentAlignment="Left" Click="OpenCreatureWorkspaceClick"><TextBlock Text="♟  Creatures &amp; NPCs" TextWrapping="Wrap" /></Button>
                        <Button HorizontalContentAlignment="Left" Click="OpenGameObjectWorkspaceClick"><TextBlock Text="▱  Gameobjects" TextWrapping="Wrap" /></Button>
                        <Button HorizontalContentAlignment="Left" Click="OpenQuestWorkspaceClick"><TextBlock Text="✦  Quests" TextWrapping="Wrap" /></Button>
                        <Button HorizontalContentAlignment="Left" Click="OpenPetWorkspaceClick"><TextBlock Text="♞  Pets &amp; companions" TextWrapping="Wrap" /></Button>
                        <Button HorizontalContentAlignment="Left" Click="OpenBehaviorWorkspaceClick"><TextBlock Text="⌘  Behaviors &amp; dialogue" TextWrapping="Wrap" /></Button>
                        <Button HorizontalContentAlignment="Left" Click="OpenMpqWorkspaceClick"><TextBlock Text="◇  MPQ patches" TextWrapping="Wrap" /></Button>
                        <Button HorizontalContentAlignment="Left" Click="OpenClientWorkspaceClick"><TextBlock Text="▣  Client workshop" TextWrapping="Wrap" /></Button>
                        <Button HorizontalContentAlignment="Left" Click="OpenMapWorkspaceClick"><TextBlock Text="▦  Maps &amp; world" TextWrapping="Wrap" /></Button>
                        <Button HorizontalContentAlignment="Left" Click="OpenTextureWorkspaceClick"><TextBlock Text="▧  Texture lab" TextWrapping="Wrap" /></Button>
                        <Button HorizontalContentAlignment="Left" Click="OpenAssetComparisonClick"><TextBlock Text="⬡  Assets &amp; compare" TextWrapping="Wrap" /></Button>
                        <Button HorizontalContentAlignment="Left" Click="OpenNativeConversionClick"><TextBlock Text="⇄  Modern asset conversion" TextWrapping="Wrap" /></Button>
                        <Button HorizontalContentAlignment="Left" Click="OpenToolInventoryClick"><TextBlock Text="⌂  Tool inventory" TextWrapping="Wrap" /></Button>
                        <Button HorizontalContentAlignment="Left" Click="OpenServerSqlClick"><TextBlock Text="⚙  Server &amp; SQL" TextWrapping="Wrap" /></Button>
                        <Button HorizontalContentAlignment="Left" Click="OpenSqlWorkspaceClick"><TextBlock Text="▤  Full SQL database · tables, queries &amp; favorites" TextWrapping="Wrap" /></Button>
                    </StackPanel>
                </ScrollViewer>
                <Border Grid.Row="2" Margin="0,8,0,0" Padding="10" CornerRadius="6" Background="#131925" BorderBrush="#273044" BorderThickness="1">
                    <StackPanel Spacing="5">
                        <TextBlock Text="Performance mode" FontWeight="SemiBold" />
                        <TextBlock Text="No animations · direct-rendered tables · background file I/O · Devbug optional" TextWrapping="Wrap" Foreground="#8E99AD" FontSize="11" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <GridSplitter x:Name="NavigationSplitter" Grid.Row="1" Grid.Column="1" ResizeDirection="Columns" Background="#2B3445" />

        <Grid x:Name="EditorWorkspace" Grid.Row="1" Grid.Column="2" RowDefinitions="Auto,*" Background="#090C11">
            <Border BorderBrush="#2B3445" BorderThickness="0,0,0,1" Background="#0E131C">
                <Grid RowDefinitions="Auto,Auto">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="DocumentTabsPanel" Orientation="Horizontal" VerticalAlignment="Bottom" />
                    </ScrollViewer>
                    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <WrapPanel Margin="6,4" Orientation="Horizontal">
                            <Button Margin="0,0,4,0" Content="Undo" Padding="8,4" Click="UndoClick" />
                            <Button Margin="0,0,4,0" Content="Redo" Padding="8,4" Click="RedoClick" />
                            <Button Margin="0,0,4,0" Content="+ Row" Padding="8,4" Click="AddRowClick" />
                            <Button Margin="0,0,4,0" Content="Clone" Padding="8,4" Click="CloneRowClick" />
                            <Button Margin="0,0,4,0" Content="Clone ×…" Padding="8,4" Click="CloneMultipleClick" />
                            <Button Margin="0,0,4,0" Content="Delete" Padding="8,4" Click="DeleteRowClick" />
                            <Button Margin="0,0,4,0" Content="Spell workspace" Padding="8,4" Click="OpenSpellWorkspaceClick" />
                            <ToggleSwitch x:Name="DecodedToggle" OnContent="Decoded" OffContent="Raw" IsChecked="True" Margin="4,0" IsCheckedChanged="DecodedChanged" />
                        </WrapPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
            <Grid Grid.Row="1">
                <Grid x:Name="WelcomePanel">
                    <Border Margin="18" CornerRadius="12" Padding="34" BorderBrush="#2A3447" BorderThickness="1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                <GradientStop Color="#182233" Offset="0" />
                                <GradientStop Color="#0E131C" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel Spacing="13">
                            <TextBlock Text="Crucible, rebuilt for speed." FontSize="28" FontWeight="SemiBold" />
                            <TextBlock Text="This is the first native Avalonia workspace. Open a WotLK WDBC table to test the custom virtual viewport against a real client or server dataset." Foreground="#A7B0C0" TextWrapping="Wrap" LineHeight="21" />
                            <WrapPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Classes="accent" Content="Open a DBC" Click="OpenDbcClick" />
                                <Button Margin="8,0,0,0" Content="Preview an M2" Click="OpenM2Click" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </Grid>
                <Grid x:Name="DbcHost" IsVisible="False" RowDefinitions="*,Auto" ColumnDefinitions="*,Auto">
                    <local:VirtualDbcView x:Name="DbcView" />
                    <ScrollBar x:Name="VerticalDbcScroll" Grid.Column="1" Orientation="Vertical" SmallChange="25" LargeChange="500" ValueChanged="DbcScrollChanged" />
                    <ScrollBar x:Name="HorizontalDbcScroll" Grid.Row="1" Orientation="Horizontal" SmallChange="156" LargeChange="624" ValueChanged="DbcScrollChanged" />
                </Grid>
                <local:M2PreviewView x:Name="M2View" IsVisible="False" />
            </Grid>
        </Grid>

        <GridSplitter x:Name="InspectorSplitter" Grid.Row="1" Grid.Column="3" ResizeDirection="Columns" Background="#2B3445" />

        <Border x:Name="InspectorPane" Grid.Row="1" Grid.Column="4" BorderBrush="#2B3445" BorderThickness="1,0,0,0" Background="#0E1219">
            <Grid RowDefinitions="Auto,Auto,*" Margin="14">
                <TextBlock Text="INSPECTOR" Foreground="#7F8A9F" FontSize="10" FontWeight="Bold" Margin="2,4,0,12" />
                <StackPanel Grid.Row="1" Spacing="8">
                    <TextBlock x:Name="InspectorTitle" Text="Nothing selected" FontSize="17" FontWeight="SemiBold" />
                    <TextBlock x:Name="InspectorSummary" Text="Open a table or model to begin." TextWrapping="Wrap" Foreground="#939EB1" />
                </StackPanel>
                <Border Grid.Row="2" Margin="0,18,0,0" CornerRadius="7" BorderBrush="#283247" BorderThickness="1" Background="#0A0E15">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <TextBlock x:Name="InspectorDetail" Text="Table metadata and selection details appear here." Margin="14" TextWrapping="Wrap" Foreground="#7F8A9F" FontFamily="Cascadia Mono,Consolas" FontSize="11" />
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="MainStatusBar" Grid.Row="2" Grid.ColumnSpan="5" BorderBrush="#2B3445" BorderThickness="0,1,0,0" Background="#0B0F16">
            <Grid ColumnDefinitions="*,Auto" Margin="12,0">
                <TextBlock x:Name="StatusText" Text="Ready" VerticalAlignment="Center" Foreground="#98A2B4" FontSize="11" />
                <TextBlock x:Name="RenderText" Grid.Column="1" Text="Viewport idle" VerticalAlignment="Center" Foreground="#758197" FontSize="11" />
            </Grid>
        </Border>

        <Border x:Name="FeatureWorkspaceHost" Grid.Row="0" Grid.RowSpan="3" Grid.ColumnSpan="5" IsVisible="False" Background="#090C11" />
        <Grid x:Name="CommandPaletteHost" Grid.Row="0" Grid.RowSpan="3" Grid.ColumnSpan="5" IsVisible="False" Background="#B805070A" ColumnDefinitions="*,4*,*" RowDefinitions="*,6*,*">
            <Border Grid.Row="1" Grid.Column="1" Padding="16" CornerRadius="10" BorderBrush="#4A5A76" BorderThickness="1" Background="#111722">
                <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="9">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Spacing="2">
                            <TextBlock Text="COMMAND PALETTE" Foreground="#C58A2B" FontSize="10" FontWeight="Bold" />
                            <TextBlock Text="Search every native workspace and common action" FontSize="17" FontWeight="SemiBold" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="Close · Esc" Click="CloseCommandPaletteClick" />
                    </Grid>
                    <TextBox x:Name="CommandPaletteSearch" Grid.Row="1" PlaceholderText="Try: cut items, Heidi favorites, MPQ merge, model viewer, server restart…" />
                    <Grid Grid.Row="2">
                        <ListBox x:Name="CommandPaletteResults" HorizontalAlignment="Stretch" Background="#0A0E15" BorderBrush="#283247" BorderThickness="1" />
                        <TextBlock x:Name="CommandPaletteEmptyText" Text="No command matches every search term." IsVisible="False" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#8793A7" />
                    </Grid>
                    <Grid Grid.Row="3" ColumnDefinitions="*,Auto">
                        <TextBlock x:Name="CommandPaletteStatus" Foreground="#8793A7" FontSize="11" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="↑↓ select · Enter open · Esc close" Foreground="#8793A7" FontSize="11" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
        <Grid x:Name="DialogOverlayHost" Grid.Row="0" Grid.RowSpan="3" Grid.ColumnSpan="5" IsVisible="False" Background="#CC05070A" ColumnDefinitions="*,4*,*" RowDefinitions="*,8*,*">
            <Border Grid.Row="1" Grid.Column="1" Padding="20" CornerRadius="10" BorderBrush="#39465E" BorderThickness="1" Background="#111722">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <ContentControl x:Name="DialogContent" />
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
