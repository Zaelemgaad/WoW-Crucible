<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:WoWCrucible.Desktop.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1440" d:DesignHeight="900"
        x:Class="WoWCrucible.Desktop.MainWindow"
        Title="WoW Crucible"
        WindowStartupLocation="CenterScreen">
    <Grid x:Name="RootLayout" RowDefinitions="Auto,Auto,*,Auto" ColumnDefinitions="1.1*,Auto,3*,Auto,1.5*">
        <local:WorkspaceRuntimeStrip x:Name="RuntimeStrip" Grid.Row="0" Grid.ColumnSpan="5" />
        <Border x:Name="MainHeader" Grid.Row="1" Grid.ColumnSpan="5" BorderBrush="#2B3445" BorderThickness="0,0,0,1">
            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" Margin="14,4">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="9" Margin="0,2,10,4">
                    <TextBlock Text="WOW CRUCIBLE" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center" />
                    <TextBlock x:Name="BuildIdentityText" Foreground="#7F8A9F" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
                <WrapPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <ToggleSwitch x:Name="DevbugModeToggle" OnContent="DEVBUG ON" OffContent="DEVBUG OFF" IsCheckedChanged="DevbugModeChanged" />
                    <Border Margin="8,0,0,0" Padding="9,5" CornerRadius="5" Background="#13251F" BorderBrush="#285845" BorderThickness="1">
                        <TextBlock Text="AVALONIA PREVIEW" Foreground="#79D7A8" FontSize="11" FontWeight="SemiBold" />
                    </Border>
                </WrapPanel>
                <ScrollViewer Grid.Row="1" Grid.ColumnSpan="2" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <WrapPanel Orientation="Horizontal">
                        <Button Margin="0,0,8,0" Content="Home" Click="OpenHomeClick" />
                        <Button Margin="0,0,8,0" Classes="accent" Content="Open DBC" Click="OpenDbcClick" />
                        <WrapPanel x:Name="DbcQuickActions" IsVisible="False">
                            <Button Margin="0,0,8,0" Content="Save" Click="SaveClick" />
                            <Button Margin="0,0,8,0" Content="Save As" Click="SaveAsClick" />
                            <TextBox x:Name="SearchBox" Margin="0,0,8,0" PlaceholderText="Search loaded table…" TextChanged="SearchChanged" />
                        </WrapPanel>
                        <Button Margin="0,0,8,0" Content="Commands · Ctrl+K" Click="OpenCommandPaletteClick" />
                    </WrapPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border x:Name="NavigationPane" Grid.Row="2" Grid.Column="0" BorderBrush="#2B3445" BorderThickness="0,0,1,0" Background="#0E1219">
            <Grid RowDefinitions="Auto,*,Auto" Margin="12">
                <TextBlock Text="WORKSPACE" Foreground="#7F8A9F" FontSize="10" FontWeight="Bold" Margin="6,4,0,9" />
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="6">
                        <Button Classes="accent" HorizontalContentAlignment="Left" Click="OpenHomeClick" ToolTip.Tip="Return to the simple start page without closing staged DBC tabs."><TextBlock Text="⌂  Home" TextWrapping="Wrap" /></Button>
                        <Expander Header="START HERE" IsExpanded="True">
                            <StackPanel Spacing="4" Margin="8,4,0,4">
                                <Button HorizontalContentAlignment="Left" Click="OpenWorkspaceSetupClick" ToolTip.Tip="Remember the client, server, core, definitions, tools, projects, and staging paths once."><TextBlock Text="Workspace setup" TextWrapping="Wrap" /></Button>
                                <Button HorizontalContentAlignment="Left" Click="OpenProjectWorkspaceClick" ToolTip.Tip="Keep one feature's DBC, SQL, MPQ, and allocated IDs together."><TextBlock Text="Projects &amp; shared IDs" TextWrapping="Wrap" /></Button>
                            </StackPanel>
                        </Expander>
                        <Expander Header="CREATE GAME CONTENT">
                            <StackPanel Spacing="4" Margin="8,4,0,4">
                                <Button HorizontalContentAlignment="Left" Click="OpenItemWorkbenchClick" ToolTip.Tip="Create, clone, edit, and audit items and item sets."><TextBlock Text="Items &amp; item sets" TextWrapping="Wrap" /></Button>
                                <Button HorizontalContentAlignment="Left" Click="OpenCreatureWorkspaceClick" ToolTip.Tip="Create NPCs and creatures, appearances, spawns, vendors, loot, quests, and trainers."><TextBlock Text="Creatures &amp; NPCs" TextWrapping="Wrap" /></Button>
                                <Button HorizontalContentAlignment="Left" Click="OpenQuestWorkspaceClick" ToolTip.Tip="Edit complete quests, objectives, rewards, text, and giver relationships."><TextBlock Text="Quests" TextWrapping="Wrap" /></Button>
                                <Button HorizontalContentAlignment="Left" Click="OpenGameObjectWorkspaceClick" ToolTip.Tip="Create doors, chests, world objects, displays, spawns, and loot."><TextBlock Text="Gameobjects" TextWrapping="Wrap" /></Button>
                                <Button HorizontalContentAlignment="Left" Click="OpenPetWorkspaceClick" ToolTip.Tip="Work with pets, companions, level curves, families, talents, and abilities."><TextBlock Text="Pets &amp; companions" TextWrapping="Wrap" /></Button>
                                <Button HorizontalContentAlignment="Left" Click="OpenBehaviorWorkspaceClick" ToolTip.Tip="Author gossip, dialogue, conditions, SmartAI, vendors, trainers, and loot."><TextBlock Text="NPC behavior &amp; dialogue" TextWrapping="Wrap" /></Button>
                            </StackPanel>
                        </Expander>
                        <Expander Header="CLIENT TABLES &amp; PATCHES">
                            <StackPanel Spacing="4" Margin="8,4,0,4">
                                <Button HorizontalContentAlignment="Left" Click="OpenEditorWorkspaceClick" ToolTip.Tip="Open and edit complete DBC/DB2 records directly."><TextBlock Text="DBC tables" TextWrapping="Wrap" /></Button>
                                <Button HorizontalContentAlignment="Left" Click="OpenLayeredDbcsClick" ToolTip.Tip="Compare base and override tables and promote only reviewed changes."><TextBlock Text="DBC layers &amp; promotion" TextWrapping="Wrap" /></Button>
                                <Button HorizontalContentAlignment="Left" Click="OpenDbdSchemasClick" ToolTip.Tip="Inspect schema definitions and validate complete DBC corpora."><TextBlock Text="Schemas &amp; validation" TextWrapping="Wrap" /></Button>
                                <Button HorizontalContentAlignment="Left" Click="OpenCacheTablesClick" ToolTip.Tip="Inspect WDB/ADB client cache records."><TextBlock Text="Client cache tables" TextWrapping="Wrap" /></Button>
                                <Button HorizontalContentAlignment="Left" Click="OpenMpqWorkspaceClick" ToolTip.Tip="Browse, extract, build, update, validate, and merge small MPQ patches."><TextBlock Text="MPQ patches &amp; merge" TextWrapping="Wrap" /></Button>
                                <Button HorizontalContentAlignment="Left" Click="OpenClientWorkspaceClick" ToolTip.Tip="Index clients, inspect effective archive layers, install patches, and manage releases."><TextBlock Text="Client workshop" TextWrapping="Wrap" /></Button>
                            </StackPanel>
                        </Expander>
                        <Expander Header="SERVER &amp; DATABASE">
                            <StackPanel Spacing="4" Margin="8,4,0,4">
                                <Button HorizontalContentAlignment="Left" Click="OpenServerSqlClick" ToolTip.Tip="Detect the installed core, configure SQL, and control SQL/AUTH/WORLD."><TextBlock Text="Connection &amp; server controls" TextWrapping="Wrap" /></Button>
                                <Button HorizontalContentAlignment="Left" Click="OpenSqlWorkspaceClick" ToolTip.Tip="Browse and edit complete live schemas, tables, rows, queries, objects, and favorites."><TextBlock Text="SQL Studio" TextWrapping="Wrap" /></Button>
                            </StackPanel>
                        </Expander>
                        <Expander Header="VISUALS &amp; WORLD · ADVANCED">
                            <StackPanel Spacing="4" Margin="8,4,0,4">
                                <Button HorizontalContentAlignment="Left" Click="OpenAssetComparisonClick" ToolTip.Tip="Compare provenance layers and preview compatible M2/SKIN models."><TextBlock Text="Assets, models &amp; compare" TextWrapping="Wrap" /></Button>
                                <Button HorizontalContentAlignment="Left" Click="OpenTextureWorkspaceClick" ToolTip.Tip="Inspect, convert, edit, compose, and trace BLP textures."><TextBlock Text="Texture lab" TextWrapping="Wrap" /></Button>
                                <Button HorizontalContentAlignment="Left" Click="OpenMapWorkspaceClick" ToolTip.Tip="Inspect and edit extracted ADT/WDT/WDL terrain and placements."><TextBlock Text="Maps &amp; world" TextWrapping="Wrap" /></Button>
                                <Button HorizontalContentAlignment="Left" Click="OpenNativeConversionClick" ToolTip.Tip="Review and down-port supported modern model and world-asset profiles."><TextBlock Text="Modern asset conversion" TextWrapping="Wrap" /></Button>
                            </StackPanel>
                        </Expander>
                        <Expander Header="HELP, IMPORT &amp; DIAGNOSTICS">
                            <StackPanel Spacing="4" Margin="8,4,0,4">
                                <Button HorizontalContentAlignment="Left" Click="OpenKnowledgeClick"><TextBlock Text="Field help &amp; offline wiki" TextWrapping="Wrap" /></Button>
                                <Button HorizontalContentAlignment="Left" Click="OpenDbcImportClick"><TextBlock Text="Import rows into current DBC" TextWrapping="Wrap" /></Button>
                                <Button HorizontalContentAlignment="Left" Click="OpenDbcExportClick"><TextBlock Text="Export current DBC rows" TextWrapping="Wrap" /></Button>
                                <Button HorizontalContentAlignment="Left" Click="CloseDocumentClick"><TextBlock Text="Close current DBC" TextWrapping="Wrap" /></Button>
                                <Button HorizontalContentAlignment="Left" Click="OpenToolInventoryClick"><TextBlock Text="Legacy-tool coverage" TextWrapping="Wrap" /></Button>
                                <Button HorizontalContentAlignment="Left" Click="OpenCliGuideClick"><TextBlock Text="CLI guide" TextWrapping="Wrap" /></Button>
                                <Button HorizontalContentAlignment="Left" Click="OpenLogsClick"><TextBlock Text="Logs" TextWrapping="Wrap" /></Button>
                                <Button x:Name="NavigationPaneButton" HorizontalContentAlignment="Left" Content="Hide workspace pane" Click="ToggleNavigationPaneClick" />
                                <Button x:Name="InspectorPaneButton" HorizontalContentAlignment="Left" Content="Hide inspector pane" Click="ToggleInspectorPaneClick" />
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
                <Border Grid.Row="2" Margin="0,8,0,0" Padding="10" CornerRadius="6" Background="#131925" BorderBrush="#273044" BorderThickness="1">
                    <StackPanel Spacing="5">
                        <TextBlock Text="Performance mode" FontWeight="SemiBold" />
                        <TextBlock Text="No animations · direct-rendered tables · background file I/O · Devbug optional" TextWrapping="Wrap" Foreground="#8E99AD" FontSize="11" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <GridSplitter x:Name="NavigationSplitter" Grid.Row="2" Grid.Column="1" ResizeDirection="Columns" Background="#2B3445" />

        <Grid x:Name="EditorWorkspace" Grid.Row="2" Grid.Column="2" RowDefinitions="Auto,*" Background="#090C11">
            <Border x:Name="DbcDocumentToolbar" IsVisible="False" BorderBrush="#2B3445" BorderThickness="0,0,0,1" Background="#0E131C">
                <Grid RowDefinitions="Auto,Auto">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="DocumentTabsPanel" Orientation="Horizontal" VerticalAlignment="Bottom" />
                    </ScrollViewer>
                    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <WrapPanel Margin="6,4" Orientation="Horizontal">
                            <Button Margin="0,0,4,0" Content="Undo" Padding="8,4" Click="UndoClick" />
                            <Button Margin="0,0,4,0" Content="Redo" Padding="8,4" Click="RedoClick" />
                            <Button Margin="0,0,4,0" Content="+ Row" Padding="8,4" Click="AddRowClick" />
                            <Button Margin="0,0,4,0" Content="Clone" Padding="8,4" Click="CloneRowClick" />
                            <Button Margin="0,0,4,0" Content="Clone ×…" Padding="8,4" Click="CloneMultipleClick" />
                            <Button Margin="0,0,4,0" Content="Delete" Padding="8,4" Click="DeleteRowClick" />
                            <Button Margin="0,0,4,0" Content="Spell workspace" Padding="8,4" Click="OpenSpellWorkspaceClick" />
                            <Button Margin="0,0,4,0" Content="Staging database" Padding="8,4" Click="OpenDbcStagingClick" />
                            <ToggleSwitch x:Name="DecodedToggle" OnContent="Decoded" OffContent="Raw" IsChecked="True" Margin="4,0" IsCheckedChanged="DecodedChanged" />
                        </WrapPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
            <Grid Grid.Row="1">
                <Grid x:Name="WelcomePanel">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="18" Spacing="12">
                            <Border CornerRadius="12" Padding="24" BorderBrush="#2A3447" BorderThickness="1">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                        <GradientStop Color="#182233" Offset="0" />
                                        <GradientStop Color="#0E131C" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel Spacing="8">
                                    <TextBlock Text="What do you want to work on?" FontSize="26" FontWeight="SemiBold" />
                                    <TextBlock Text="Start with a guided editor. Raw tables, conversion, and diagnostic tools remain available under the grouped workspace pane when you need them." Foreground="#A7B0C0" TextWrapping="Wrap" LineHeight="20" />
                                </StackPanel>
                            </Border>
                            <Border Padding="18" BorderBrush="#293347" BorderThickness="1" CornerRadius="9">
                                <Grid ColumnDefinitions="2*,3*" ColumnSpacing="18">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Create or change gameplay" FontSize="18" FontWeight="SemiBold" />
                                        <TextBlock Text="Friendly editors that coordinate readable fields with complete SQL and client data." TextWrapping="Wrap" Foreground="#9AA5B7" />
                                    </StackPanel>
                                    <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                                        <Button Classes="accent" Content="Items &amp; sets" Click="OpenItemWorkbenchClick" />
                                        <Button Content="Creatures &amp; NPCs" Click="OpenCreatureWorkspaceClick" />
                                        <Button Content="Quests" Click="OpenQuestWorkspaceClick" />
                                    </WrapPanel>
                                </Grid>
                            </Border>
                            <Border Padding="18" BorderBrush="#293347" BorderThickness="1" CornerRadius="9">
                                <Grid ColumnDefinitions="2*,3*" ColumnSpacing="18">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Edit client data and build a patch" FontSize="18" FontWeight="SemiBold" />
                                        <TextBlock Text="Use this for raw DBC work, client archives, and the final MPQ sent to players." TextWrapping="Wrap" Foreground="#9AA5B7" />
                                    </StackPanel>
                                    <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                                        <Button Classes="accent" Content="Open DBC" Click="OpenDbcClick" />
                                        <Button Content="MPQ patches" Click="OpenMpqWorkspaceClick" />
                                        <Button Content="Client workshop" Click="OpenClientWorkspaceClick" />
                                    </WrapPanel>
                                </Grid>
                            </Border>
                            <Border Padding="18" BorderBrush="#293347" BorderThickness="1" CornerRadius="9">
                                <Grid ColumnDefinitions="2*,3*" ColumnSpacing="18">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Manage the server and database" FontSize="18" FontWeight="SemiBold" />
                                        <TextBlock Text="Check the configured install, control services, browse every live table, or edit exact rows." TextWrapping="Wrap" Foreground="#9AA5B7" />
                                    </StackPanel>
                                    <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                                        <Button Classes="accent" Content="SQL Studio" Click="OpenSqlWorkspaceClick" />
                                        <Button Content="Connection &amp; controls" Click="OpenServerSqlClick" />
                                        <Button Content="Workspace setup" Click="OpenWorkspaceSetupClick" />
                                    </WrapPanel>
                                </Grid>
                            </Border>
                            <Border Padding="18" BorderBrush="#293347" BorderThickness="1" CornerRadius="9">
                                <Grid ColumnDefinitions="2*,3*" ColumnSpacing="18">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Visual assets and world editing" FontSize="18" FontWeight="SemiBold" />
                                        <TextBlock Text="Advanced texture, model, comparison, conversion, and extracted-map workflows." TextWrapping="Wrap" Foreground="#9AA5B7" />
                                    </StackPanel>
                                    <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                                        <Button Content="Assets &amp; models" Click="OpenAssetComparisonClick" />
                                        <Button Content="Textures" Click="OpenTextureWorkspaceClick" />
                                        <Button Content="Maps &amp; world" Click="OpenMapWorkspaceClick" />
                                    </WrapPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
                <Grid x:Name="DbcHost" IsVisible="False" RowDefinitions="*,Auto" ColumnDefinitions="*,Auto">
                    <local:VirtualDbcView x:Name="DbcView" />
                    <ScrollBar x:Name="VerticalDbcScroll" Grid.Column="1" Orientation="Vertical" SmallChange="25" LargeChange="500" ValueChanged="DbcScrollChanged" />
                    <ScrollBar x:Name="HorizontalDbcScroll" Grid.Row="1" Orientation="Horizontal" SmallChange="156" LargeChange="624" ValueChanged="DbcScrollChanged" />
                </Grid>
                <local:M2PreviewView x:Name="M2View" IsVisible="False" />
            </Grid>
        </Grid>

        <GridSplitter x:Name="InspectorSplitter" Grid.Row="2" Grid.Column="3" ResizeDirection="Columns" Background="#2B3445" />

        <Border x:Name="InspectorPane" Grid.Row="2" Grid.Column="4" BorderBrush="#2B3445" BorderThickness="1,0,0,0" Background="#0E1219">
            <Grid RowDefinitions="Auto,Auto,*" Margin="14">
                <TextBlock Text="INSPECTOR" Foreground="#7F8A9F" FontSize="10" FontWeight="Bold" Margin="2,4,0,12" />
                <StackPanel Grid.Row="1" Spacing="8">
                    <TextBlock x:Name="InspectorTitle" Text="Nothing selected" FontSize="17" FontWeight="SemiBold" />
                    <TextBlock x:Name="InspectorSummary" Text="Open a table or model to begin." TextWrapping="Wrap" Foreground="#939EB1" />
                </StackPanel>
                <Border Grid.Row="2" Margin="0,18,0,0" CornerRadius="7" BorderBrush="#283247" BorderThickness="1" Background="#0A0E15">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <TextBlock x:Name="InspectorDetail" Text="Table metadata and selection details appear here." Margin="14" TextWrapping="Wrap" Foreground="#7F8A9F" FontFamily="Cascadia Mono,Consolas" FontSize="11" />
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="MainStatusBar" Grid.Row="3" Grid.ColumnSpan="5" BorderBrush="#2B3445" BorderThickness="0,1,0,0" Background="#0B0F16">
            <Grid ColumnDefinitions="*,Auto" Margin="12,0">
                <TextBlock x:Name="StatusText" Text="Ready" VerticalAlignment="Center" Foreground="#98A2B4" FontSize="11" />
                <TextBlock x:Name="RenderText" Grid.Column="1" Text="Viewport idle" VerticalAlignment="Center" Foreground="#758197" FontSize="11" />
            </Grid>
        </Border>

        <Border x:Name="FeatureWorkspaceHost" Grid.Row="1" Grid.RowSpan="3" Grid.ColumnSpan="5" IsVisible="False" Background="#090C11" />
        <Grid x:Name="CommandPaletteHost" Grid.Row="0" Grid.RowSpan="4" Grid.ColumnSpan="5" IsVisible="False" Background="#B805070A" ColumnDefinitions="*,4*,*" RowDefinitions="*,6*,*">
            <Border Grid.Row="1" Grid.Column="1" Padding="16" CornerRadius="10" BorderBrush="#4A5A76" BorderThickness="1" Background="#111722">
                <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="9">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Spacing="2">
                            <TextBlock Text="COMMAND PALETTE" Foreground="#C58A2B" FontSize="10" FontWeight="Bold" />
                            <TextBlock Text="Search every native workspace and common action" FontSize="17" FontWeight="SemiBold" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="Close · Esc" Click="CloseCommandPaletteClick" />
                    </Grid>
                    <TextBox x:Name="CommandPaletteSearch" Grid.Row="1" PlaceholderText="Try: cut items, Heidi favorites, MPQ merge, model viewer, server restart…" />
                    <Grid Grid.Row="2">
                        <ListBox x:Name="CommandPaletteResults" HorizontalAlignment="Stretch" Background="#0A0E15" BorderBrush="#283247" BorderThickness="1" />
                        <TextBlock x:Name="CommandPaletteEmptyText" Text="No command matches every search term." IsVisible="False" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#8793A7" />
                    </Grid>
                    <Grid Grid.Row="3" ColumnDefinitions="*,Auto">
                        <TextBlock x:Name="CommandPaletteStatus" Foreground="#8793A7" FontSize="11" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="↑↓ select · Enter open · Esc close" Foreground="#8793A7" FontSize="11" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
        <Grid x:Name="DialogOverlayHost" Grid.Row="0" Grid.RowSpan="4" Grid.ColumnSpan="5" IsVisible="False" Background="#CC05070A" ColumnDefinitions="*,4*,*" RowDefinitions="*,8*,*">
            <Border Grid.Row="1" Grid.Column="1" Padding="20" CornerRadius="10" BorderBrush="#39465E" BorderThickness="1" Background="#111722">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <ContentControl x:Name="DialogContent" />
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
